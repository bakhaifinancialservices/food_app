# ─────────────────────────────────────────────
# COPY THIS FILE TO .env AND FILL IN YOUR KEYS
# Never commit .env to GitHub
# ─────────────────────────────────────────────

# Groq API key — get free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# USDA FoodData Central — get free at api.nal.usda.gov
USDA_API_KEY=y0SIZADpVOBF9kNj77wZcRTq0kOsMUFjIuTzLfof

# HuggingFace token — ONLY needed if Groq Scout fallback is triggered
# Get free at huggingface.co/settings/tokens
# Leave blank during hackathon unless fallback is needed
HF_TOKEN=

# Set to "true" to force HuggingFace fallback (for testing fallback path)
USE_HF_FALLBACK=false

# Optional: Nutritionix (register at nutritionix.com/business/api)
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=
